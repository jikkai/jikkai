{
  "name": "asaki",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prepare": "simple-git-hooks",
    "lint": "oxlint . --deny-warnings",
    "lint:fix": "oxlint . --fix --deny-warnings"
  },
  "devDependencies": {
    "lint-staged": "^16.4.0",
    "oxlint": "^1.57.0",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,tsx}": "oxlint --fix --deny-warnings"
  }
}
